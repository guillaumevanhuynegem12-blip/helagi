# Copy this file to ".env.local" and fill in real values.
# .env.local is gitignored and is never sent to the browser.

# Anthropic API key (server-side only). Get it from https://console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# WHO ICD-11 API (server-side only) — official disease names + ICD codes.
# Register for free at https://icd.who.int/icdapi -> "API Access" to get these.
WHO_ICD_CLIENT_ID=your-client-id
WHO_ICD_CLIENT_SECRET=your-client-secret

# Upstash Redis (for per-IP rate limiting — see lib/rateLimit.ts).
# Get these from https://console.upstash.com -> your Redis database -> "REST API"
UPSTASH_REDIS_REST_URL=https://your-db-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# Transactional email — signup verification codes + password-reset links
# (lib/email.ts). Without an API key, emails are printed to the server console
# instead (fine locally, never in production). Get a key at
# https://resend.com -> API Keys. The default sender (onboarding@resend.dev)
# can only email the Resend account owner — for real visitors, verify your
# domain in Resend and set EMAIL_FROM to an address on it.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM="Helagi <no-reply@your-domain.com>"

# "Sign in with Google" (optional — the button only appears when both values
# are set). Create an OAuth client at
# https://console.cloud.google.com/apis/credentials
#   -> "Create credentials" -> "OAuth client ID" -> type "Web application",
# and register these authorized redirect URIs on it:
#   http://localhost:3000/api/auth/google/callback    (local development)
#   https://YOUR-DOMAIN/api/auth/google/callback      (production)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
